<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/balance_card_gradient">

    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PENGELOLAAN KEUANGAN\nMAHASISWA"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.35"/>

    <TextView
        android:id="@+id/tvSubTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fitur Prioritas Pengeluaran &amp; Tabungan"
        android:textColor="@android:color/white"
        android:alpha="0.85"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppTitle"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEnter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MASUK APLIKASI"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        app:backgroundTint="@android:color/white"
        app:cornerRadius="24dp"
        android:paddingVertical="14dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="64dp"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tugas Pemrograman Berorientasi Objek (Java PBO)"
        android:textColor="@android:color/white"
        android:alpha="0.6"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/btnEnter"/>

</androidx.constraintlayout.widget.ConstraintLayout>
